PORT=8080
NODE_ENV=development

# Comma-separated API keys accepted by the gateway. Leave empty for local development only.
GATEWAY_API_KEYS=dev-key

# Routing: balanced | cost | latency
ROUTING_STRATEGY=balanced
REQUEST_TIMEOUT_MS=30000
CACHE_TTL_SECONDS=300
RATE_LIMIT_RPM=60

# Provider keys. Mock provider is enabled by default for local testing.
MOCK_PROVIDER_ENABLED=true
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
